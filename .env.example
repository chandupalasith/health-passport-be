NODE_ENV=development
PORT=5001

MONGO_URI=mongodb://localhost:27017/health-passport
JWT_SECRET=change_me_to_a_long_random_string

# ── AWS S3 (required in production for letterhead image storage) ────────────
# In development, files are stored locally in backend/uploads/letterheads/
# In production (NODE_ENV=production), these must be set.
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=health-passport-uploads
# Leave blank in production if the EC2/EB instance has an IAM role with S3 access
# (preferred). Only set these if using IAM user credentials directly.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── SMS providers ──────────────────────────────────────────────────────────
DIALOG_ESMS_API_KEY=your_dialog_esms_api_key
DIALOG_ESMS_SOURCE=HealthPass

NOTIFY_USER_ID=your_notify_user_id
NOTIFY_API_KEY=your_notify_api_key
NOTIFY_SENDER_ID=NotifyDEMO

# ── Frontend ───────────────────────────────────────────────────────────────
# Set to your CloudFront/S3 website URL in production
FRONTEND_URL=http://localhost:3000
